---
import { profile } from '../data/site';

interface Props {
  size?: 'sm' | 'md';
  showEmail?: boolean;
  class?: string;
}

const { size = 'md', showEmail = false, class: className = '' } = Astro.props;
const iconClass = size === 'sm' ? 'h-5 w-5' : 'h-6 w-6';
---

<ul class={`flex items-center gap-5 ${className}`} aria-label="Social media">
  <li>
    <a
      href={profile.github}
      target="_blank"
      rel="noreferrer noopener"
      class="text-[color:var(--color-text)] hover:text-[color:var(--color-accent)] transition-colors"
      aria-label="GitHub (opens in a new tab)"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class={iconClass}>
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2 .37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
      </svg>
    </a>
  </li>
  <li>
    <a
      href={profile.linkedin}
      target="_blank"
      rel="noreferrer noopener"
      class="text-[color:var(--color-text)] hover:text-[color:var(--color-accent)] transition-colors"
      aria-label="LinkedIn (opens in a new tab)"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class={iconClass}>
        <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.05-1.86-3.05-1.86 0-2.14 1.45-2.14 2.95v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.86 3.37-1.86 3.6 0 4.27 2.37 4.27 5.45v6.3ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.72C24 .77 23.2 0 22.22 0Z"/>
      </svg>
    </a>
  </li>
  {showEmail && (
    <li>
      <a
        href={`mailto:${profile.email}`}
        class="text-[color:var(--color-text)] hover:text-[color:var(--color-accent)] transition-colors"
        aria-label={`Email ${profile.email}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class={iconClass}>
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="m3 7 9 6 9-6" />
        </svg>
      </a>
    </li>
  )}
</ul>
