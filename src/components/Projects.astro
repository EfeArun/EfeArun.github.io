---
import Section from './Section.astro';
import { projects } from '../data/site';

const base = import.meta.env.BASE_URL;
---

<Section id="projects" label="Projects" number="03">
  <ul class="space-y-8">
    {projects.map((project) => {
      const hasGithub = project.github && project.github !== '#';
      return (
        <li
          class="group/card relative grid grid-cols-1 gap-6 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-bg-elevated)]/30 p-5 transition-all hover:border-[color:var(--color-accent)]/50 hover:bg-[color:var(--color-bg-elevated)]/60 sm:grid-cols-[minmax(0,11rem)_1fr] sm:p-6 lg:grid-cols-[minmax(0,16rem)_1fr] lg:gap-8 lg:p-7"
        >
          <figure class="overflow-hidden rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-bg)]">
            <img
              src={project.image}
              alt={project.imageAlt}
              loading="lazy"
              decoding="async"
              width="800"
              height="500"
              class="aspect-[8/5] w-full object-cover transition-transform duration-500 group-hover/card:scale-[1.03]"
            />
          </figure>

          <div class="flex flex-col">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-6">
              <h3 class="text-lg font-semibold text-[color:var(--color-text-bright)] sm:text-xl">
                <a
                  href={`${base}projects/${project.slug}/`}
                  class="rounded transition-colors before:absolute before:inset-0 before:rounded-lg before:content-[''] hover:text-[color:var(--color-accent)] focus-visible:outline-none focus-visible:before:ring-2 focus-visible:before:ring-[color:var(--color-accent)]/60"
                  aria-label={`View ${project.title}`}
                >
                  {project.title}
                </a>
              </h3>
              <div class="shrink-0 text-left sm:text-right">
                <div class="font-mono text-2xl font-semibold tracking-tight text-[color:var(--color-accent)] sm:text-3xl">
                  {project.metric}
                </div>
                {project.metricLabel && (
                  <div class="mt-0.5 text-[11px] uppercase tracking-wider text-[color:var(--color-text)]/70">
                    {project.metricLabel}
                  </div>
                )}
              </div>
            </div>

            <p class="mt-3 text-sm leading-relaxed text-[color:var(--color-text)] sm:text-base">
              {project.description}
            </p>

            <ul class="mt-4 flex flex-wrap gap-1.5" aria-label="Technologies used">
              {project.stack.map((tech) => (
                <li>
                  <span class="inline-flex items-center rounded-full bg-[color:var(--color-accent)]/10 px-2.5 py-0.5 font-mono text-[11px] font-medium leading-5 text-[color:var(--color-accent)]">
                    {tech}
                  </span>
                </li>
              ))}
            </ul>

            <div class="relative z-10 mt-5 flex flex-wrap items-center gap-3">
              {hasGithub && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noreferrer noopener"
                  class="inline-flex items-center gap-2 rounded-md border border-[color:var(--color-border)] bg-transparent px-3 py-1.5 text-xs font-medium text-[color:var(--color-text-soft)] transition-colors hover:border-[color:var(--color-accent)]/60 hover:text-[color:var(--color-accent)]"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2 .37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
                  </svg>
                  Code
                </a>
              )}
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noreferrer noopener"
                  class="inline-flex items-center gap-2 rounded-md bg-[color:var(--color-accent)]/15 px-3 py-1.5 text-xs font-medium text-[color:var(--color-accent)] transition-colors hover:bg-[color:var(--color-accent)]/25"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <path d="M15 3h6v6"/>
                    <path d="M10 14 21 3"/>
                  </svg>
                  Live demo
                </a>
              )}
            </div>
          </div>
        </li>
      );
    })}
  </ul>
</Section>
