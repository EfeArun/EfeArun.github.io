---
import Section from './Section.astro';
import { skillGroups } from '../data/site';
---

<Section id="skills" label="Skills" number="02">
  <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {skillGroups.map((group) => (
      <li
        class="rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-bg-elevated)]/40 p-5 transition-colors hover:border-[color:var(--color-accent)]/40 hover:bg-[color:var(--color-bg-elevated)]/70"
      >
        <h3 class="mb-3 font-mono text-xs font-medium uppercase tracking-widest text-[color:var(--color-accent)]">
          {group.title}
        </h3>
        <ul class="flex flex-wrap gap-2">
          {group.skills.map((skill) => (
            <li class="rounded-full bg-[color:var(--color-accent)]/10 px-3 py-1 text-xs font-medium leading-5 text-[color:var(--color-accent)]">
              {skill}
            </li>
          ))}
        </ul>
      </li>
    ))}
  </ul>
</Section>
