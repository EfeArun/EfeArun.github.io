---
import SocialLinks from './SocialLinks.astro';
import { profile, navItems } from '../data/site';
---

<header
  id="top-nav"
  class="fixed inset-x-0 top-0 z-40 -translate-y-full border-b border-transparent bg-[color:var(--color-bg)]/80 opacity-0 backdrop-blur-md transition-all duration-300"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-3 md:px-12">
    <a
      href="#hero"
      class="font-mono text-sm font-semibold tracking-tight text-[color:var(--color-text-bright)] hover:text-[color:var(--color-accent)] transition-colors"
    >
      {profile.shortName}
    </a>

    <nav aria-label="Section navigation" class="hidden sm:block">
      <ul class="flex items-center gap-6">
        {navItems.map((item) => (
          <li>
            <a
              href={`#${item.id}`}
              data-nav-link={item.id}
              class="nav-text text-xs font-semibold uppercase tracking-widest text-[color:var(--color-text)] hover:text-[color:var(--color-accent)] transition-colors"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <SocialLinks size="sm" class="hidden sm:flex" />
  </div>
</header>

<!-- Mobile: when nav is shown, a compact menu button appears -->

<style>
  #top-nav.is-visible {
    transform: translateY(0);
    opacity: 1;
    border-bottom-color: var(--color-border);
  }
</style>
